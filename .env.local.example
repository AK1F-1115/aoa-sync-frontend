# ==============================================================================
# AOA Sync Frontend — Required Environment Variables
# Copy this file to .env.local and fill in your values.
# ==============================================================================

# ------------------------------------------------------------------------------
# Shopify App Configuration
# NEXT_PUBLIC_ prefix makes this available client-side.
# The API key is intentionally public — this is normal for embedded Shopify apps.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SHOPIFY_API_KEY=your_shopify_api_key_here

# ------------------------------------------------------------------------------
# Backend API Base URL
# Points to the AOA backend. Change to http://localhost:8000 for local dev.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=https://api.aoatraders.com

# ==============================================================================
# FUTURE: WorkOS (do NOT add until feature/workos-auth branch)
# These are placeholders only — do not uncomment until WorkOS branch is started.
# ------------------------------------------------------------------------------
# WORKOS_API_KEY=sk_...                         # SERVER-SIDE ONLY (no NEXT_PUBLIC_)
# WORKOS_CLIENT_ID=client_...
# NEXT_PUBLIC_WORKOS_REDIRECT_URI=https://app.aoatraders.com/auth/callback
# ==============================================================================
